{
    "name":  "@ges/contentful-record-picker",
    "version":  "0.1.0",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "dev":  "vite --host 0.0.0.0",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "create-app-definition":  "contentful-app-scripts create-app-definition",
                    "upload":  "contentful-app-scripts upload --bundle-dir ./dist",
                    "upload-ci":  "contentful-app-scripts upload --bundle-dir ./dist --ci",
                    "activate":  "contentful-app-scripts activate",
                    "typecheck":  "tsc -b --pretty false",
                    "lint":  "eslint src --max-warnings 0"
                },
    "dependencies":  {
                         "@contentful/app-sdk":  "^4.51.0",
                         "@contentful/field-editor-rich-text":  "6.4.1",
                         "@lingui/core":  "^5.3.0",
                         "@lingui/message-utils":  "^5.3.0",
                         "@tanstack/react-query":  "^5.0.0",
                         "react":  "^19.1.0",
                         "react-dom":  "^19.1.0"
                     },
    "devDependencies":  {
                            "@contentful/app-scripts":  "^0.13.42",
                            "@types/react":  "^19.1.6",
                            "@types/react-dom":  "^19.1.5",
                            "@vitejs/plugin-react":  "^4.5.2",
                            "typescript":  "^5.8.3",
                            "vite":  "^6.3.5"
                        },
    "overrides":  {
                      "slate":  "0.94.1",
                      "slate-react":  "0.102.0"
                  }
}
