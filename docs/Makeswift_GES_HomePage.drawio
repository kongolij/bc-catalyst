          <mxGeometry x="1140" y="100" width="520" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="ui_home" value="MakeswiftHomePage (client)&#10;home-page/client.tsx&#10;&#10;'use client';&#10;const t = useTranslations('Home');&#10;const { featuredProducts, newestProducts } = useMakeswiftHomePageData();" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10;fontStyle=1" vertex="1" parent="lane_ui">
