        <mxCell id="ui_slide"   value="&lt;Slideshow /&gt;                 (fixed)"       style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="lane_ui"><mxGeometry x="20"  y="230" width="480" height="30" as="geometry"/></mxCell>
