  <!-- ================================================================ -->
  <!-- Page 1 — Overview: registration + request flow                   -->
  <!-- ================================================================ -->
  <diagram name="1. Overview" id="page-overview">
    <mxGraphModel dx="2000" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Makeswift &amp;mdash; GES Home Page Template Architecture (bc-catalyst/core)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Two flows share the same ReactRuntime singleton: (a) client-side registration wires every component into the runtime, (b) the server request path fetches a snapshot and hydrates the template with BC data." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontColor=#555" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="1500" height="30" as="geometry"/>
        </mxCell>

        <!-- Swimlane: Registration -->
        <mxCell id="lane_reg" value="Registration flow (browser boot)" style="swimlane;fontSize=14;fontStyle=1;html=1;startSize=30;fillColor=#DAE8FC;strokeColor=#6C8EBF" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="480" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="reg_provider" value="MakeswiftProvider (client)&#10;&#10;core/components/makeswift/provider.tsx&#10;&#10;'use client';&#10;wraps app in &lt;ReactRuntimeProvider&gt;&#10;side-effect: import '~/lib/makeswift/components'" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F1FF;strokeColor=#2b6cb0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11" vertex="1" parent="lane_reg">
          <mxGeometry x="20" y="50" width="440" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="reg_barrel" value="components/index.ts  (barrel)&#10;&#10;core/lib/makeswift/components/index.ts&#10;&#10;imports every ./&lt;component&gt;/register&#10;side-effect: calls runtime.registerComponent(...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F1FF;strokeColor=#2b6cb0;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11" vertex="1" parent="lane_reg">
          <mxGeometry x="20" y="200" width="440" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="reg_home_reg" value="home-page/register.ts&#10;&#10;runtime.registerComponent(MakeswiftHomePage, {&#10;  type: 'ges-home-page-template',&#10;  label: 'GES / Home Page Template',&#10;  props: {&#10;    top:         Slot(),&#10;    afterHero:   Slot(),&#10;    middle:      Slot(),&#10;    belowNewest: Slot(),&#10;    bottom:      Slot(),&#10;  },&#10;});" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="lane_reg">
          <mxGeometry x="20" y="340" width="440" height="230" as="geometry"/>
        </mxCell>
        <mxCell id="reg_runtime" value="runtime.ts  (module-level singleton)&#10;&#10;export const runtime = new ReactRuntime();&#10;&#10;every register.ts file mutates this same instance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6D5;strokeColor=#b7791f;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11" vertex="1" parent="lane_reg">
          <mxGeometry x="20" y="600" width="440" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="reg_builder" value="Makeswift Builder (external, authoring)&#10;&#10;editor drops 'GES / Home Page Template' on '/'&#10;fills 5 Slot props with any registered component" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F1FF;strokeColor=#2b6cb0;dashed=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11" vertex="1" parent="lane_reg">
          <mxGeometry x="20" y="740" width="440" height="110" as="geometry"/>
        </mxCell>

        <!-- Reg arrows -->
        <mxCell id="ea1" style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2" edge="1" parent="1" source="reg_provider" target="reg_barrel">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ea2" value="fan-out imports" style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2;labelBackgroundColor=#ffffff" edge="1" parent="1" source="reg_barrel" target="reg_home_reg">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ea3" value="registerComponent()" style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2;labelBackgroundColor=#ffffff" edge="1" parent="1" source="reg_home_reg" target="reg_runtime">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ea4" value="publish snapshot" style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2;dashed=1;labelBackgroundColor=#ffffff" edge="1" parent="1" source="reg_builder" target="reg_runtime">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Swimlane: Request -->
        <mxCell id="lane_req" value="Request flow (server render)" style="swimlane;fontSize=14;fontStyle=1;html=1;startSize=30;fillColor=#F8CECC;strokeColor=#B85450" vertex="1" parent="1">
          <mxGeometry x="560" y="100" width="540" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="req_page" value="app/[locale]/(default)/page.tsx&#10;&#10;const siteVersion = await getSiteVersion();&#10;const makeswiftSnapshot = await client.getPageSnapshot('/', {&#10;  siteVersion, locale, allowLocaleFallback: true,&#10;});&#10;&#10;return (&#10;  &lt;HomePageDataProvider&gt;&#10;    {makeswiftSnapshot&#10;      ? &lt;MakeswiftPage snapshot={makeswiftSnapshot} /&gt;&#10;      : &lt;MakeswiftHomePage /&gt;}&#10;  &lt;/HomePageDataProvider&gt;&#10;);" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8E8;strokeColor=#c53030;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="lane_req">
          <mxGeometry x="20" y="50" width="500" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="req_data_provider" value="HomePageDataProvider (server component)&#10;&#10;core/app/[locale]/(default)/home-page-data-provider.tsx&#10;&#10;const streamablePageData = Streamable.from(async () =&gt; {&#10;  const token = await getSessionCustomerAccessToken();&#10;  const currency = await getPreferredCurrencyCode();&#10;  return getPageData(currency, token);&#10;});&#10;&#10;const streamableFeaturedProducts = Streamable.from(async () =&gt; ... );&#10;const streamableNewestProducts   = Streamable.from(async () =&gt; ... );" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8E8;strokeColor=#c53030;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="lane_req">
          <mxGeometry x="20" y="290" width="500" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="req_context" value="&lt;MakeswiftHomePageDataProvider value={{ featuredProducts, newestProducts }}&gt;&#10;&#10;home-page/data-context.tsx (createContext&lt;HomePageData&gt;)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0E6FF;strokeColor=#7c3aed;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="lane_req">
          <mxGeometry x="20" y="530" width="500" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="req_makeswiftPage" value="&lt;MakeswiftPage snapshot=... /&gt;&#10;&#10;@makeswift/runtime/next&#10;- deserializes tree from snapshot&#10;- looks up type 'ges-home-page-template' on runtime&#10;- hydrates 5 Slot props with authored ReactNodes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6D5;strokeColor=#b7791f;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11" vertex="1" parent="lane_req">
          <mxGeometry x="20" y="640" width="500" height="140" as="geometry"/>
        </mxCell>

