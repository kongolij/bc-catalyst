        <mxCell id="m11" value="renders: {top} + Slideshow + {afterHero} + FeaturedProductList + {middle} + FeaturedProductCarousel + {belowNewest} + Subscribe + {bottom}" style="endArrow=classic;html=1;strokeColor=#333" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1570" y="740" as="sourcePoint"/><mxPoint x="1570" y="780" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m12" value="streamed HTML + RSC payload" style="endArrow=classic;html=1;strokeColor=#333;dashed=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="390" y="850" as="sourcePoint"/><mxPoint x="140" y="850" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m13" value="Suspense boundaries resolve as Streamable data arrives" style="endArrow=classic;html=1;strokeColor=#c53030;dashed=1" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="1570" y="900" as="sourcePoint"/><mxPoint x="140" y="900" as="targetPoint"/></mxGeometry></mxCell>

        <mxCell id="note1" value="Note: HomePageDataProvider does NOT await the BC call before rendering. The Streamable is passed into context immediately, and product sections render inside Suspense boundaries that resolve when the promise settles." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=10" vertex="1" parent="1">
