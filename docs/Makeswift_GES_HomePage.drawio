          <mxGeometry x="620" y="100" width="720" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="rn_wrap" value="&lt;div style={{ position: 'relative', left: '50%', width: '100vw', transform: 'translateX(-50%)' }}&gt;&#10;/* full-bleed wrapper: escapes any max-width parent */" style="rounded=1;html=1;fillColor=#FFF6D5;strokeColor=#b7791f;align=left;spacingLeft=8;spacingTop=6;fontFamily=Consolas;fontSize=10;verticalAlign=top" vertex="1" parent="rn_box"><mxGeometry x="20" y="40" width="680" height="60" as="geometry"/></mxCell>

        <mxCell id="rn_top"     value="{top}"                                            style="rounded=1;html=1;fillColor=#E8F1FF;strokeColor=#2b6cb0;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="120" width="680" height="45" as="geometry"/></mxCell>
        <mxCell id="rn_slide"   value="&lt;Slideshow /&gt;  (Catalyst slideshow feature)"      style="rounded=1;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="180" width="680" height="45" as="geometry"/></mxCell>
        <mxCell id="rn_ah"      value="{afterHero}"                                      style="rounded=1;html=1;fillColor=#E8F1FF;strokeColor=#2b6cb0;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="240" width="680" height="45" as="geometry"/></mxCell>
        <mxCell id="rn_fpl"     value="&lt;FeaturedProductList products={featuredProducts} title=... cta=... /&gt;"   style="rounded=1;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="300" width="680" height="45" as="geometry"/></mxCell>
        <mxCell id="rn_mid"     value="{middle}"                                         style="rounded=1;html=1;fillColor=#E8F1FF;strokeColor=#2b6cb0;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="360" width="680" height="45" as="geometry"/></mxCell>
        <mxCell id="rn_fpc"     value="&lt;FeaturedProductCarousel products={newestProducts} title=... /&gt;"          style="rounded=1;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="420" width="680" height="45" as="geometry"/></mxCell>
        <mxCell id="rn_bn"      value="{belowNewest}"                                    style="rounded=1;html=1;fillColor=#E8F1FF;strokeColor=#2b6cb0;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="480" width="680" height="45" as="geometry"/></mxCell>
        <mxCell id="rn_sub"     value="&lt;Subscribe /&gt;   (newsletter component)"           style="rounded=1;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="540" width="680" height="45" as="geometry"/></mxCell>
        <mxCell id="rn_bot"     value="{bottom}"                                         style="rounded=1;html=1;fillColor=#E8F1FF;strokeColor=#2b6cb0;align=left;spacingLeft=8;fontFamily=Consolas;fontSize=11" vertex="1" parent="rn_box"><mxGeometry x="20" y="600" width="680" height="45" as="geometry"/></mxCell>

        <mxCell id="rn_note" value="Alignment rules&#10;- Fixed sections (green) always render, even when the Slot above/below is empty.&#10;- Empty Slots collapse to null on published pages (`unstable_placeholder: builderOnly` hides the drop zone outside the editor).&#10;- The full-bleed wrapper means Slot content is expected to manage its own inner max-width / padding; drop a Layouts / Section component if you need centered content." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=10" vertex="1" parent="rn_box">
          <mxGeometry x="20" y="670" width="680" height="180" as="geometry"/>
        </mxCell>

        <!-- Slot -> render mappings -->
        <mxCell id="ma_top" style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2;dashed=1" edge="1" parent="1" source="reg_top" target="rn_top"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ma_ah"  style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2;dashed=1" edge="1" parent="1" source="reg_ah"  target="rn_ah"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ma_mid" style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2;dashed=1" edge="1" parent="1" source="reg_mid" target="rn_mid"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ma_bn"  style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2;dashed=1" edge="1" parent="1" source="reg_bn"  target="rn_bn"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ma_bot" style="endArrow=classic;html=1;strokeColor=#2b6cb0;strokeWidth=2;dashed=1" edge="1" parent="1" source="reg_bot" target="rn_bot"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <!-- ================================================================ -->
  <!-- Page 5 — Data & context (Streamable flow)                        -->
  <!-- ================================================================ -->
  <diagram name="5. Data / context flow" id="page-data">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="d_title" value="BC data -&gt; Streamable -&gt; React context -&gt; template" style="text;html=1;strokeColor=none;fillColor=none;align=left;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="d_page_data" value="page-data.ts (BC GraphQL query)&#10;&#10;site.featuredProducts { ... }&#10;site.newestProducts { ... }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="360" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="d_dp" value="HomePageDataProvider  (server component)&#10;core/app/[locale]/(default)/home-page-data-provider.tsx&#10;&#10;const streamablePageData = Streamable.from(async () =&gt; {&#10;  const token    = await getSessionCustomerAccessToken();&#10;  const currency = await getPreferredCurrencyCode();&#10;  return getPageData(currency, token);&#10;});&#10;&#10;const streamableFeaturedProducts = Streamable.from(async () =&gt; {&#10;  const data = await streamablePageData;&#10;  return productCardTransformer(&#10;    removeEdgesAndNodes(data.site.featuredProducts), format);&#10;});&#10;&#10;const streamableNewestProducts   = Streamable.from(async () =&gt; {&#10;  const data = await streamablePageData;&#10;  return productCardTransformer(&#10;    removeEdgesAndNodes(data.site.newestProducts), format);&#10;});" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE8E8;strokeColor=#c53030;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="480" y="80" width="600" height="380" as="geometry"/>
        </mxCell>

        <mxCell id="d_ctx_provider" value="&lt;MakeswiftHomePageDataProvider&#10;   value={{ featuredProducts, newestProducts }}&gt;&#10;&#10;home-page/data-context.tsx&#10;createContext&lt;HomePageData&gt;(null)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0E6FF;strokeColor=#7c3aed;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1160" y="80" width="380" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="d_use_hook" value="useMakeswiftHomePageData()  (in client tree)&#10;&#10;return useContext(HomePageDataContext) ?? fallbackHomePageData;&#10;fallback = { featuredProducts: [], newestProducts: [] }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0E6FF;strokeColor=#7c3aed;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1160" y="300" width="380" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="d_fpl" value="&lt;FeaturedProductList products={featuredProducts} /&gt;&#10;&#10;renders inside Suspense; resolves when Streamable settles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1160" y="480" width="380" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="d_fpc" value="&lt;FeaturedProductCarousel products={newestProducts} /&gt;&#10;&#10;renders inside Suspense; resolves when Streamable settles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DFF3E4;strokeColor=#2f855a;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontFamily=Consolas;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1160" y="610" width="380" height="110" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="d_e1" value="await inside Streamable" style="endArrow=classic;html=1;strokeColor=#c53030;strokeWidth=2;labelBackgroundColor=#ffffff" edge="1" parent="1" source="d_page_data" target="d_dp"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d_e2" value="context.value =" style="endArrow=classic;html=1;strokeColor=#7c3aed;strokeWidth=2;labelBackgroundColor=#ffffff" edge="1" parent="1" source="d_dp" target="d_ctx_provider"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d_e3" value="useContext" style="endArrow=classic;html=1;strokeColor=#7c3aed;strokeWidth=2;dashed=1;labelBackgroundColor=#ffffff" edge="1" parent="1" source="d_ctx_provider" target="d_use_hook"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d_e4" style="endArrow=classic;html=1;strokeColor=#2f855a;strokeWidth=2" edge="1" parent="1" source="d_use_hook" target="d_fpl"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="d_e5" style="endArrow=classic;html=1;strokeColor=#2f855a;strokeWidth=2" edge="1" parent="1" source="d_use_hook" target="d_fpc"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Explanations -->
        <mxCell id="d_why" value="Why the indirection?&#10;&#10;- Server components fetch BC data (auth, currency, GraphQL) which can't run in the browser.&#10;- The template itself is a client component (Makeswift Slots need a client boundary).&#10;- Streamable + React context lets the server hand promises to the client without awaiting them, so the shell paints immediately and product sections stream in.&#10;- Fallback = empty arrays: the template still renders inside the Makeswift Builder iframe where no data provider is mounted." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#666;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="1080" height="200" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
